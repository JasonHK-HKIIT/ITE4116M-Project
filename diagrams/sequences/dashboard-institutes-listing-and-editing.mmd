sequenceDiagram
    actor User
    participant View as View Layer<br/>(institutes.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant InstituteModel as Model Layer<br/>(Institute)
    participant CampusModel as Model Layer<br/>(Campus)
    participant DB as Database

    %% Initial Page Load
    User->>View: Access institutes page
    View->>Controller: Component initialization
    Controller->>Controller: mount()
    Controller->>InstituteModel: Institute::make()
    InstituteModel-->>Controller: New empty institute instance
    Controller->>CampusModel: Campus::all()
    CampusModel->>DB: SELECT * FROM campuses
    DB-->>CampusModel: All campuses
    CampusModel-->>Controller: campusOptions collection
    
    Controller->>Controller: with() - Prepare data
    Controller->>Controller: headers() - Build table headers
    Controller->>Controller: institutes() - Build query
    
    Controller->>InstituteModel: Institute::query()
    
    alt Sort by translation field (name)
        Controller->>InstituteModel: orderByTranslation(column, direction)
    else Sort by non-translation field
        Controller->>InstituteModel: orderBy(column, direction)
    end
    
    Controller->>InstituteModel: get()
    InstituteModel->>DB: Execute SELECT query with campuses relation
    DB-->>InstituteModel: Return institutes with campuses
    InstituteModel-->>Controller: Collection of institutes
    
    Controller-->>View: Return headers, institutes, exists
    View-->>User: Display institutes table with badges

    %% Search/Filter
    User->>View: Search (wire:model.live)
    View->>Controller: Update keywords
    Controller->>Controller: institutes() - Rebuild query
    Controller->>InstituteModel: Query with filters
    InstituteModel->>DB: Execute filtered query
    DB-->>InstituteModel: Filtered results
    InstituteModel-->>Controller: Filtered institutes
    Controller-->>View: Re-render table
    View-->>User: Display filtered results

    %% Sort Column
    User->>View: Sort column (click header)
    View->>Controller: Update sortBy
    Controller->>Controller: institutes() - Rebuild query
    Controller->>InstituteModel: Query with new sorting
    InstituteModel->>DB: Execute sorted query
    DB-->>InstituteModel: Sorted results
    InstituteModel-->>Controller: Sorted institutes
    Controller-->>View: Re-render table
    View-->>User: Display sorted results

    %% Create Institute
    User->>View: Click create button
    View->>Controller: createInstitute()
    Controller->>InstituteModel: Institute::make()
    InstituteModel-->>Controller: New empty institute
    Controller->>Controller: showInstituteModel()
    Controller->>Controller: resetErrorBag()
    Controller->>Controller: Build empty name array
    Controller->>Controller: Reset campus_ids = []
    Controller->>Controller: Set instituteModal = true
    Controller-->>View: Render modal
    View-->>User: Show create institute modal

    User->>View: Fill form fields<br/>(name translations, campuses)
    View->>Controller: wire:model updates
    
    User->>View: Submit form (wire:submit="save")
    View->>Controller: save()
    Controller->>Controller: Check institute->exists = false
    Controller->>Controller: validate()
    Controller->>Controller: LocalesHelper::transformToModelFields()
    
    Controller->>InstituteModel: fill($fields except campus_ids)
    Controller->>InstituteModel: campuses()->sync(campus_ids)
    InstituteModel->>DB: Sync pivot table (campus_institute)
    DB-->>InstituteModel: Success
    Controller->>InstituteModel: save()
    InstituteModel->>DB: INSERT INTO institutes
    DB-->>InstituteModel: Success
    InstituteModel-->>Controller: Institute saved
    
    Controller-->>View: success('Institute created')
    Controller->>Controller: Set instituteModal = false
    Controller->>Controller: institutes() - Refresh list
    Controller->>InstituteModel: Query updated list
    InstituteModel->>DB: Execute query
    DB-->>InstituteModel: Return results
    InstituteModel-->>Controller: Updated institutes
    Controller-->>View: Close modal & re-render table
    View-->>User: Show success & updated list

    %% Update Institute
    User->>View: Click edit button
    View->>Controller: updateInstitute(id)
    Controller->>InstituteModel: Institute::findOrFail(id)
    InstituteModel->>DB: SELECT * FROM institutes WHERE id = ?
    DB-->>InstituteModel: Institute data with campuses relation
    InstituteModel-->>Controller: Existing institute instance
    
    Controller->>Controller: showInstituteModel()
    Controller->>Controller: resetErrorBag()
    Controller->>InstituteModel: getTranslationsArray()
    InstituteModel-->>Controller: Translations data
    Controller->>Controller: LocalesHelper::transformToProperties()
    Controller->>InstituteModel: campuses collection
    InstituteModel-->>Controller: Related campuses
    Controller->>Controller: Map campus IDs to array
    Controller->>Controller: Set instituteModal = true
    Controller-->>View: Render modal with data
    View-->>User: Show edit institute modal

    User->>View: Modify form fields
    View->>Controller: wire:model updates
    
    User->>View: Submit form
    View->>Controller: save()
    Controller->>Controller: Check institute->exists = true
    Controller->>Controller: validate()
    Controller->>Controller: LocalesHelper::transformToModelFields()
    
    Controller->>InstituteModel: fill($fields except campus_ids)
    Controller->>InstituteModel: campuses()->sync(campus_ids)
    InstituteModel->>DB: Sync pivot table
    DB-->>InstituteModel: Success
    Controller->>InstituteModel: save()
    InstituteModel->>DB: UPDATE institutes
    DB-->>InstituteModel: Success
    InstituteModel-->>Controller: Institute updated
    
    Controller-->>View: success('Institute updated')
    Controller->>Controller: Set instituteModal = false
    Controller->>Controller: institutes() - Refresh list
    Controller->>InstituteModel: Query updated list
    InstituteModel->>DB: Execute query
    DB-->>InstituteModel: Return results
    InstituteModel-->>Controller: Updated institutes
    Controller-->>View: Close modal & re-render table
    View-->>User: Show success & updated list

    %% Delete Institute
    User->>View: Click delete button
    View->>Controller: deleteArticle(id)
    Note over Controller: Bug: Method should be deleteInstitute<br/>Currently calls deleteArticle
    Controller->>InstituteModel: Institute::destroy(id)
    InstituteModel->>DB: DELETE FROM institutes
    DB-->>InstituteModel: Success
    InstituteModel-->>Controller: Deletion count
    Controller-->>View: success('Institute deleted')
    Controller->>Controller: institutes() - Refresh list
    Controller->>InstituteModel: Query updated list
    InstituteModel->>DB: Execute query
    DB-->>InstituteModel: Return results
    InstituteModel-->>Controller: Updated institutes
    Controller-->>View: Re-render table
    View-->>User: Show success & updated list
