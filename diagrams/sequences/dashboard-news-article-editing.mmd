sequenceDiagram
    actor User
    participant View as View Layer<br/>(edit.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Model as Model Layer<br/>(NewsArticle)
    participant DB as Database
    participant Storage as Media Storage

    User->>View: Access edit page
    View->>Controller: mount(NewsArticle $article)
    Controller->>Model: Check if article exists
    Model-->>Controller: Article data
    
    alt Article exists
        Controller->>Model: getTranslationsArray()
        Model-->>Controller: Translated fields (title, content)
        Controller->>Controller: Fill form with existing data
    else New article
        Controller->>Controller: Initialize empty content
    end
    
    Controller->>Controller: with() - Prepare statuses
    Controller-->>View: Render form with data
    View-->>User: Display form

    User->>View: Fill/Edit form fields<br/>(title, slug, status, cover, content)
    View->>Controller: wire:model updates
    
    User->>View: Upload cover image
    View->>Controller: wire:model="cover"
    Controller->>Controller: Store temporary file
    Controller-->>View: temporaryUrl()
    View-->>User: Preview image

    User->>View: Submit form (wire:submit="save")
    View->>Controller: save()
    
    Controller->>Controller: Generate slug if empty
    Controller->>Controller: Set published_on if published
    Controller->>Controller: validate()
    Controller->>Controller: LocalesHelper::transformToModelFields()
    
    Controller->>Model: fill($fields)
    Controller->>Model: save()
    Model->>DB: UPDATE/INSERT news_articles
    DB-->>Model: Success
    Model-->>Controller: Article saved

    alt Cover image uploaded
        Controller->>Model: clearMediaCollection('cover')
        Model->>Storage: Delete old image
        Controller->>Model: addMedia()->toMediaCollection('cover')
        Model->>Storage: Store new image
        Storage-->>Model: Success
    end

    alt Existing article
        Controller-->>View: success('Article updated')
        View-->>User: Show success message
    else New article
        Controller-->>View: success() + redirect
        View->>Controller: Redirect to edit page
        Controller-->>View: Render with new article
        View-->>User: Show success + redirect
    end
