sequenceDiagram
    actor User
    participant View as View Layer<br/>(list.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Model as Model Layer<br/>(Resource)
    participant Translation as ResourceTranslation<br/>(Model)
    participant DB as Database
    participant Storage as Media Storage

    User->>View: Access /dashboard/resources
    View->>Controller: Component initialization
    Controller->>Controller: Initialize properties<br/>(perPage, keywords, etc.)
    
    Controller->>Controller: documents() method
    Controller->>Controller: Get current locale
    Controller->>Model: Resource::query()
    Model->>Model: with(['translations.media'])
    
    alt Has keywords filter
        Model->>Model: whereHas('translations')<br/>whereFullText(['title'], keywords)
    end
    
    alt Has publishedAfter filter
        Model->>Model: where('updated_at', '>=', date)
    end
    
    alt Has publishedBefore filter
        Model->>Model: where('updated_at', '<=', date)
    end
    
    Model->>Model: orderByDesc('updated_at')
    Model->>Model: paginate(perPage)
    Model->>DB: Execute query with eager loading
    DB-->>Model: Resource records with translations
    Model-->>Controller: Paginated resources
    
    Controller->>Controller: map() - Transform resources
    loop Each resource
        Controller->>Translation: Get translations for locale
        Translation-->>Controller: Main translation title
        
        Controller->>Translation: Loop through all translations
        loop Each translation
            Translation->>Storage: getMedia('resources')
            Storage-->>Translation: Media collection
            Translation-->>Controller: Media with metadata<br/>(file_name, url, locale, size)
        end
        
        Controller->>Controller: Build resource object<br/>(id, title, media, latest_date)
    end
    
    Controller->>Controller: Create custom paginator
    Controller->>Controller: headers() method
    Controller->>Controller: with() - Prepare view data
    Controller-->>View: Render with headers & documents
    View-->>User: Display resources table

    User->>View: Enter search keywords
    View->>Controller: wire:model.live.debounce="keywords"
    Controller->>Controller: Update $keywords property
    Controller->>Controller: Recompute documents()
    Controller->>Model: Resource::query() with filters
    Model->>DB: Execute filtered query
    DB-->>Model: Filtered records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display filtered results

    User->>View: Open filters drawer
    View->>Controller: @click="$wire.isDrawerOpened = true"
    Controller->>Controller: Set isDrawerOpened = true
    Controller-->>View: Update drawer state
    View-->>User: Show filters drawer

    User->>View: Set date filters
    View->>Controller: wire:model.live="publishedAfter/Before"
    Controller->>Controller: Update date properties
    Controller->>Controller: Recompute documents()
    Controller->>Model: Resource::query() with filters
    Model->>DB: Execute filtered query
    DB-->>Model: Filtered records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display filtered results

    User->>View: Click expand row
    View->>Controller: wire:model="expanded"
    Controller->>Controller: Update $expanded array
    Controller-->>View: Toggle expansion state
    View->>Translation: Access $row->media
    Translation-->>View: Media collection with:<br/>- file_name<br/>- locale<br/>- size<br/>- url
    View-->>User: Display expanded row with files

    User->>View: Click download file
    View->>Storage: $media->url (getFullUrl())
    Storage-->>View: File URL
    View-->>User: Download file in new tab

    User->>View: Click "Edit" button
    View-->>User: Navigate to dashboard.resources.edit

    User->>View: Click "Delete" button
    View->>Controller: wire:click="deleteResource(id)"
    Controller->>Model: Resource::find(id)
    Model->>DB: SELECT * FROM resources<br/>WHERE id = ?
    DB-->>Model: Resource record
    Model-->>Controller: Resource instance with translations
    
    Controller->>Translation: Loop through translations
    loop Each translation
        Translation->>Storage: getMedia('resources')
        Storage-->>Translation: Media collection
        loop Each media
            Translation->>Storage: delete()
            Storage-->>Translation: Media deleted
        end
        Translation->>DB: DELETE FROM resource_translations
        DB-->>Translation: Translation deleted
    end
    
    Controller->>Model: delete()
    Model->>DB: DELETE FROM resources<br/>WHERE id = ?
    DB-->>Model: Resource deleted
    Model-->>Controller: Deletion complete
    
    Controller->>Controller: success('Resource was deleted.')
    Controller->>Controller: Recompute documents()
    Controller-->>View: Re-render table with toast
    View-->>User: Show success message

    User->>View: Click "Reset" filters
    View->>Controller: wire:click="clear"
    Controller->>Controller: clear() method
    Controller->>Controller: reset(['keywords', dates])
    Controller->>Controller: Recompute documents()
    Controller->>Model: Resource::query() without filters
    Model->>DB: Execute unfiltered query
    DB-->>Model: All records
    Model-->>Controller: Reset pagination
    Controller-->>View: Re-render table
    View-->>User: Display all resources

    User->>View: Click "Create" button
    View-->>User: Navigate to dashboard.resources.create

    User->>View: Change perPage value
    View->>Controller: Per page selection changed
    Controller->>Controller: Update $perPage property
    Controller->>Controller: Recompute documents()
    Controller->>Model: paginate(new perPage)
    Model->>DB: Execute query with new limit
    DB-->>Model: Paginated records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display updated pagination
