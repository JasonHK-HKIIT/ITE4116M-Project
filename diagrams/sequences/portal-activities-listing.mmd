sequenceDiagram
    actor User
    participant View as View Layer<br/>(list.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Model as Model Layer<br/>(Activity)
    participant DB as Database

    User->>View: Access activities list page
    View->>Controller: Component initialization
    Controller->>Controller: Initialize properties<br/>(perPage, keywords, sortBy, etc.)
    
    Controller->>Controller: activities() method
    Controller->>Model: Activity::query()
    
    alt Has keywords filter
        Model->>Model: whereFullText(['title', 'instructor', 'activity_code'])
    end
    
    alt Has execution date range
        Model->>Model: where('execution_from', '>=', from)<br/>where('execution_to', '<=', to)
    end
    
    alt Sorting by execution_from
        Model->>Model: orderBy('execution_from', direction)
    end
    
    alt Sorting by execution_to
        Model->>Model: orderBy('execution_to', direction)
    end
    
    alt Sorting by instructor
        Model->>Model: orderBy('instructor', direction)
    end
    
    alt Sorting by title
        Model->>Model: orderBy('title', direction)
    end
    
    alt Sorting by total_amount
        Model->>Model: orderBy('total_amount', direction)
    end
    
    Model->>Model: paginate(perPage)
    Model->>DB: Execute query
    DB-->>Model: Activity records with pagination
    Model-->>Controller: Paginated activities
    
    Controller->>Controller: headers() method
    Controller->>Controller: with() - Prepare view data
    Controller-->>View: Render with headers & activities
    View-->>User: Display activities table

    User->>View: Enter search keywords
    View->>Controller: wire:model.live.debounce="keywords"
    Controller->>Controller: Update $keywords property
    Controller->>Controller: updatingKeywords() - resetPage()
    Controller->>Controller: Recompute activities()
    Controller->>Model: Activity::query() with filters
    Model->>DB: Execute filtered query
    DB-->>Model: Filtered records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display filtered results

    User->>View: Open filters drawer
    View->>Controller: @click="$wire.isDrawerOpened = true"
    Controller->>Controller: Set isDrawerOpened = true
    Controller-->>View: Update drawer state
    View-->>User: Show filters drawer

    User->>View: Set execution date filters
    View->>Controller: wire:model.live="execution_from/to"
    Controller->>Controller: Update date properties
    Controller->>Controller: updatingExecutionFrom/To() - resetPage()
    Controller->>Controller: Recompute activities()
    Controller->>Model: Activity::query() with filters
    Model->>DB: Execute filtered query
    DB-->>Model: Filtered records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display filtered results

    User->>View: Click column header to sort
    View->>Controller: wire:model="sortBy"
    Controller->>Controller: Update $sortBy array
    Controller->>Controller: Recompute activities()
    Controller->>Model: Activity::query() with orderBy
    Model->>DB: Execute sorted query
    DB-->>Model: Sorted records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display sorted results

    User->>View: Change perPage value
    View->>Controller: Per page selection changed
    Controller->>Controller: Update $perPage property
    Controller->>Controller: Recompute activities()
    Controller->>Model: paginate(new perPage)
    Model->>DB: Execute query with new limit
    DB-->>Model: Paginated records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display updated pagination

    User->>View: Click "Reset" filters
    View->>Controller: wire:click="clear"
    Controller->>Controller: clear() method
    Controller->>Controller: reset(['keywords', dates])
    Controller->>Controller: Recompute activities()
    Controller->>Model: Activity::query() without filters
    Model->>DB: Execute unfiltered query
    DB-->>Model: All records
    Model-->>Controller: Reset pagination
    Controller-->>View: Re-render table
    View-->>User: Display all activities

    User->>View: Click "Activity Details" button
    View-->>User: Navigate to portal.activities.show route

    User->>View: Navigate to pagination page
    View->>Controller: Pagination link clicked
    Controller->>Controller: Update page number
    Controller->>Controller: Recompute activities()
    Controller->>Model: paginate() with new page
    Model->>DB: Execute query with offset
    DB-->>Model: Page records
    Model-->>Controller: Updated pagination
    Controller-->>View: Re-render table
    View-->>User: Display new page
