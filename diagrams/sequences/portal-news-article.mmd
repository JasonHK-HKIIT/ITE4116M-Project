sequenceDiagram
    actor User
    participant View as View Layer<br/>(show.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Model as Model Layer<br/>(NewsArticle)
    participant DB as Database
    participant Storage as Media Storage

    User->>View: Access /news/{slug}
    View->>Controller: Component initialization
    Controller->>Controller: mount($slug)
    
    Controller->>Model: NewsArticle::where('slug', slug)
    Model->>DB: SELECT * FROM news_articles<br/>WHERE slug = ?
    
    alt Article exists
        DB-->>Model: Article record
        Model-->>Controller: NewsArticle instance
        Controller->>Controller: Set $article property
        Controller-->>View: Render article page
        
        View->>Model: getFirstMediaUrl('cover')
        Model->>Storage: Retrieve cover image URL
        Storage-->>Model: Image URL
        Model-->>View: Cover image URL
        
        View-->>User: Display article with:<br/>- Title<br/>- Published date<br/>- Cover image<br/>- Content<br/>- Back button
        
    else Article not found
        Model-->>Controller: ModelNotFoundException
        Controller-->>View: 404 error
        View-->>User: Show 404 page
    end

    User->>View: Click "Back to News List"
    View-->>User: Navigate to portal.news.list route
