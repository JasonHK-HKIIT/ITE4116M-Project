sequenceDiagram
    actor User
    participant View as View Layer<br/>(login.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Auth as Auth Facade<br/>(Laravel Auth)
    participant Model as Model Layer<br/>(User)
    participant Session as Session Layer
    participant DB as Database

    User->>View: Access login page
    View->>Controller: mount()
    Controller->>Auth: user() - Check if authenticated
    
    alt User already logged in
        Auth-->>Controller: User instance
        Controller-->>View: redirect("/")
        View-->>User: Redirect to homepage
    else User not logged in
        Auth-->>Controller: null
        Controller-->>View: Render login form
        View-->>User: Display login form
    end

    User->>View: Enter credentials & submit
    View->>Controller: wire:submit="login"
    
    Controller->>Controller: validate()
    
    alt Validation fails
        Controller-->>View: Validation errors
        View-->>User: Show error messages
    else Validation passes
        Controller->>Auth: attempt($credentials)
        Auth->>Model: Find user by username
        Model->>DB: SELECT * FROM users WHERE username = ?
        DB-->>Model: User record
        Model-->>Auth: User instance
        Auth->>Auth: Verify password hash
        
        alt Credentials invalid
            Auth-->>Controller: false
            Controller->>Controller: addError("username", "...")
            Controller-->>View: Error message
            View-->>User: Show error message
        else Credentials valid
            Auth->>Session: Create user session
            Session->>Session: regenerate()
            Auth-->>Controller: true
            Controller-->>View: redirect()->intended("/")
            View-->>User: Redirect to homepage
        end
    end
