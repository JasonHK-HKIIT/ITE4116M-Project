sequenceDiagram
    actor User
    participant View as View Layer<br/>(programme-modules.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Auth as Auth Facade
    participant UserModel as User Model
    participant StudentModel as Student Model
    participant ProgrammeModel as Programme Model
    participant ModuleModel as Module Model
    participant DB as Database

    User->>View: Access /profile/programme-modules
    View->>Controller: Component initialization
    Controller->>Controller: mount()
    
    Controller->>Controller: studentProgrammes()
    Controller->>Auth: user()
    Auth-->>Controller: User instance
    
    alt User is admin OR no student record
        Controller->>Controller: Return empty collection
        Controller->>Controller: Set $expanded = []
        Controller-->>View: Render empty state
        View-->>User: Display "No Programme Code" message
    else User is student
        Controller->>UserModel: $user->student
        UserModel->>DB: SELECT * FROM students<br/>WHERE user_id = ?
        DB-->>UserModel: Student record
        UserModel-->>Controller: Student instance
        
        Controller->>StudentModel: $student->programmes()
        StudentModel->>DB: SELECT * FROM programmes<br/>JOIN student_programme<br/>WHERE student_id = ?
        DB-->>StudentModel: Programme records
        StudentModel->>ProgrammeModel: Get programmes
        ProgrammeModel-->>StudentModel: Programme collection
        StudentModel-->>Controller: Programmes collection
        
        Controller->>Controller: pluck('id')->toArray()
        Controller->>Controller: Set $expanded = [programme IDs]
        
        Controller->>Controller: headers() method
        Controller->>Controller: with() - Prepare view data
        Controller-->>View: Render with programmes
        
        View->>ProgrammeModel: Access programme properties
        ProgrammeModel-->>View: programme_code, name
        
        View-->>User: Display programmes table<br/>(all rows expanded by default)
    end

    User->>View: Click to collapse programme row
    View->>Controller: wire:model="expanded"
    Controller->>Controller: Remove programme ID from $expanded
    Controller-->>View: Update expansion state
    View-->>User: Collapse programme row

    User->>View: Click to expand programme row
    View->>Controller: wire:model="expanded"
    Controller->>Controller: Add programme ID to $expanded
    Controller-->>View: Update expansion state
    
    View->>ProgrammeModel: $programme->modules
    ProgrammeModel->>DB: SELECT * FROM modules<br/>JOIN programme_module<br/>WHERE programme_id = ?
    DB-->>ProgrammeModel: Module records
    ProgrammeModel->>ModuleModel: Get modules
    ModuleModel-->>ProgrammeModel: Module collection
    ProgrammeModel-->>View: Modules collection
    
    alt Programme has no modules
        View-->>User: Display "No modules" message
    else Programme has modules
        View->>ModuleModel: Loop through modules
        ModuleModel-->>View: module_code, name
        View-->>User: Display modules table with:<br/>- Module Code<br/>- Module Title
    end
