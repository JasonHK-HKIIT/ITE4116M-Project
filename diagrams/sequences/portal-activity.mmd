sequenceDiagram
    actor User
    participant View as View Layer<br/>(show.blade.php)
    participant Controller as Controller Layer<br/>(Livewire Component)
    participant Model as Model Layer<br/>(Activity)
    participant DB as Database

    User->>View: Access /activities/{id}
    View->>Controller: Component initialization
    Controller->>Controller: mount($id)
    
    Controller->>Model: Activity::findOrFail($id)
    Model->>DB: SELECT * FROM activities<br/>WHERE id = ?
    
    alt Activity exists
        DB-->>Model: Activity record
        Model-->>Controller: Activity instance
        Controller->>Controller: Set $activity property
        Controller->>Controller: Set $selectedTab = 'administrative-tab'
        Controller->>Controller: render()
        Controller-->>View: Render activity details
        
        View->>Model: Access activity properties
        Model-->>View: Activity data (code, type, title, etc.)
        
        View->>Model: $activity->campus->name
        Model->>DB: Eager load campus relationship
        DB-->>Model: Campus record
        Model-->>View: Campus name
        
        View-->>User: Display activity with:<br/>- Administrative tab (default)<br/>- Activity code, type, title<br/>- Campus, discipline
        
    else Activity not found
        Model-->>Controller: ModelNotFoundException
        Controller-->>View: 404 error
        View-->>User: Show 404 page
    end

    User->>View: Click "Time" tab
    View->>Controller: wire:model="selectedTab"
    Controller->>Controller: Update $selectedTab = 'time-tab'
    Controller-->>View: Update active tab
    View->>Model: Access time properties
    Model-->>View: Execution dates, time slots, duration
    View-->>User: Display time information

    User->>View: Click "Personnel" tab
    View->>Controller: wire:model="selectedTab"
    Controller->>Controller: Update $selectedTab = 'personnel-tab'
    Controller-->>View: Update active tab
    View->>Model: Access personnel properties
    Model-->>View: Instructor, responsible staff
    View-->>User: Display personnel information

    User->>View: Click "Descriptive" tab
    View->>Controller: wire:model="selectedTab"
    Controller->>Controller: Update $selectedTab = 'descriptive-tab'
    Controller-->>View: Update active tab
    View->>Model: Access descriptive properties
    Model-->>View: Description, venue, venue remark
    View-->>User: Display descriptive information

    User->>View: Click "Financial" tab
    View->>Controller: wire:model="selectedTab"
    Controller->>Controller: Update $selectedTab = 'financial-tab'
    Controller-->>View: Update active tab
    View->>Model: Access financial properties
    Model-->>View: Total amount, included deposit
    View-->>User: Display financial information

    User->>View: Click "Supporting" tab
    View->>Controller: wire:model="selectedTab"
    Controller->>Controller: Update $selectedTab = 'supporting-tab'
    Controller-->>View: Update active tab
    View->>Model: Access supporting properties
    Model-->>View: Attachment, SWPD programme flag
    View-->>User: Display supporting information

    User->>View: Click "Back" or navigate away
    View-->>User: Return to activities list
