class Student {
  +int id
  +int user_id
  +int institute_id
  +int campus_id
  +string? gender
  +date? date_of_birth
  +string? nationality
  +string? mother_tongue
  +string? tel_no
  +string? mobile_no
  +string? address
  +user() BelongsTo
  +classes() BelongsToMany
  +institute() BelongsTo
  +campus() BelongsTo
}

class User {
  +int id
  +string username
  +string family_name
  +string given_name
  +string? chinese_name
  +string password
  +Role role
  +student() HasOne
}

class ClassModel {
  <<table: classes>>
  +int id
  +string class_code
  +int academic_year
  +int institute_id
  +int campus_id
  +int programme_id
  +programme() BelongsTo
  +students() BelongsToMany
}

class Programme {
  +int id
  +int institute_id
  +string programme_code
  +institute() BelongsTo
}

class Institute {
  +int id
  +campuses() BelongsToMany
}

class Campus {
  +int id
  +institutes() BelongsToMany
}

class Role {
  <<enum>>
  STUDENT
  STAFF
  ADMIN
}

class StudentClass {
  +int student_id
  +int class_id
}

class InstituteCampus {
  +int institute_id
  +int campus_id
}

