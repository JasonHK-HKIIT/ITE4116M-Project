  +transformToModelFields(validated, translatedAttributes) array
}

ProgrammeEditPageComponent ..> Programme : load/edit/save
ProgrammeEditPageComponent ..> Institute : list for select
ProgrammeEditPageComponent ..> Module : list/filter by institute
ProgrammeEditPageComponent ..> LocalesHelper : i18n field mapping and rules
ProgrammeEditPageComponent ..> ProgrammeTranslation : localized name validation/persistence

Programme "*" --> "1" Institute : belongsTo
Programme "*" -- "*" Module : belongsToMany via programme_modules
Programme "1" --> "*" ProgrammeTranslation : hasMany
Module "1" --> "*" ModuleTranslation : hasMany

ProgrammeModule .. Programme : pivot
