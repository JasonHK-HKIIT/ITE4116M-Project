  +string name
}

class ModuleTranslation {
  +int module_id
  +string locale
  +string name
}

class ProgrammeModule {
  +int programme_id
  +int module_id
}

class LocalesHelper {
  <<helper>>
  +locales() array
  +buildPropertyValue() array
  +buildRules(field, rules) array
  +buildValidationAttributes(field) array
